# spotify
# # --- Spotify Controls ---
ctrl - space : osascript -e 'tell application "Spotify" to playpause'
ctrl - end : osascript -e 'tell application "Spotify" to next track'
ctrl - right : osascript -e 'tell application "Spotify" to previous track'
ctrl + cmd - end : osascript -e 'tell application "Spotify" to set sound volume to (sound volume + 10)'
ctrl + cmd - right : osascript -e 'tell application "Spotify" to set sound volume to (sound volume - 10)'
