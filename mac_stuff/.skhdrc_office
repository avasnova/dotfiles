# problemnie bindi [ ]  
# focus prev/next space (just navigation)
cmd - 0x21 : yabai -m space --focus prev; sketchybar --trigger window_focus
cmd - 0x1E : yabai -m space --focus next; sketchybar --trigger window_focus

# move focused window to prev/next space AND follow it AND keep it focused
shift + cmd - 0x21 : wid=$(yabai -m query --windows --window | jq -r '.id'); yabai -m window "$wid" --space prev; yabai -m space --focus prev; yabai -m window --focus "$wid"; sketchybar --trigger windows_on_spaces; sketchybar --trigger window_focus
shift + cmd - 0x1E : wid=$(yabai -m query --windows --window | jq -r '.id'); yabai -m window "$wid" --space next; yabai -m space --focus next; yabai -m window --focus "$wid"; sketchybar --trigger windows_on_spaces; sketchybar --trigger window_focus

