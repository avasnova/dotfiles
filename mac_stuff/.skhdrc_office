cmd - return : open -a Ghostty
cmd - h : true

# Swap window with adjacent windows
alt - left  : yabai -m window --swap west; sketchybar --trigger window_focus
alt - right : yabai -m window --swap east; sketchybar --trigger window_focus
alt - up    : yabai -m window --swap north; sketchybar --trigger window_focus
alt - down  : yabai -m window --swap south; sketchybar --trigger window_focus

# Toggle full screen using command + F
ctrl - f : yabai -m window --toggle zoom-fullscreen; sketchybar --trigger window_focus

# Shrink window dimensions using command + M
cmd - m : yabai -m window --resize left:0:-100; yabai -m window --resize top:0:-100; sketchybar --trigger window_focus

# Focus stuff
cmd - left: yabai -m window --focus west; sketchybar --trigger window_focus
cmd - right: yabai -m window --focus east; sketchybar --trigger window_focus
cmd - up: yabai -m window --focus north; sketchybar --trigger window_focus
cmd - down: yabai -m window --focus south; sketchybar --trigger window_focus



